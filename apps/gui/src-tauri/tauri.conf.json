{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Quota Trends",
  "version": "0.1.0",
  "identifier": "dev.idaibin.codex-quota-trends",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:9811",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Codex Quota Trends",
        "width": 960,
        "height": 680,
        "minWidth": 960,
        "minHeight": 680,
        "center": true,
        "visible": false,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay"
      },
      {
        "label": "tray",
        "title": "Codex Quota Trends",
        "url": "/?surface=tray",
        "width": 420,
        "height": 500,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": ["icons/icon.png"],
    "category": "Productivity",
    "shortDescription": "Local Codex quota trends",
    "longDescription": "A local-first macOS menu bar app for Codex quota history, trends, and alerts.",
    "copyright": "Copyright 2026 Daibin"
  }
}
